# Authentication (set ENABLE_AUTH=true to require GitHub OAuth login)
ENABLE_AUTH=false
ALLOWED_USERS=alice,bob
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=           # generate with: openssl rand -hex 32
BASE_URL=http://localhost:3001

# Import directory (host path mounted into container at /data)
MBOX_DIR=~/Downloads

# Server
PORT=3001
